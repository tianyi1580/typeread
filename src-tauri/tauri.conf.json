{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BookTyper",
  "version": "0.1.0",
  "identifier": "com.tianyima.booktyper",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "BookTyper",
        "width": 1440,
        "height": 960,
        "minWidth": 1120,
        "minHeight": 720,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": []
  }
}
